# Copy to .env for local overrides (`make run` sources it; `make dev` supplies defaults itself).
ENV=local
PORT=8080
LOG_LEVEL=info
DATABASE_URL=postgres://keysmith:keysmith@localhost:5433/keysmith?sslmode=disable
AUTO_MIGRATE=false

# Token issuing. Local dev falls back to the checked-in dev keypair and
# http://localhost:8080 when these are unset; staging/production require both.
#PUBLIC_BASE_URL=https://auth.example.com
#AUTH_SIGNING_KEYS=[{"kid":"2026-07","private_key_b64":"..."}]

# Email. Local dev falls back to SMTP → mailpit (localhost:1025) when
# RESEND_API_KEY is unset; staging/production require it. SPA_ORIGIN is the
# base for verification/reset links (required outside local).
#SPA_ORIGIN=https://app.example.com
#RESEND_API_KEY=
#EMAIL_FROM=Drafted <no-reply@example.com>
